{
  "name": "afrikart-sandbox",
  "version": "2.0.0",
  "description": "Mock Fincra-style sandbox API for the Afrikart take-home",
  "type": "module",
  "main": "src/server.ts",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "start": "bun src/server.ts",
    "dev": "bun --watch src/server.ts",
