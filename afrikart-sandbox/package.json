  },
  "engines": {
    "bun": "1.3.10"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.0",
    "@valibot/to-json-schema": "^1.5.0",
    "hono": "^4.10.1",
    "hono-openapi": "^1.3.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  }
}
