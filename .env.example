# AfriKart Payment Service — environment variables
# Copy to .env and fill in values before running

# Our service port
PORT=3001

# --- Fincra sandbox credentials ---
# Point to local sandbox for dev, or hosted sandbox for judging
FINCRA_API_BASE_URL=http://localhost:4000
FINCRA_SECRET_KEY=sk_test_afrikart_secret
FINCRA_PUBLIC_KEY=pk_test_afrikart_public
FINCRA_WEBHOOK_SECRET=whsec_afrikart_secret

# SQLite database path (defaults to ./afrikart.db)
DATABASE_PATH=./afrikart.db

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Node environment
NODE_ENV=development
